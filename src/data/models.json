ائلة جمال العاصمة، مع تنقيت خطوطها المميزة في النمذجة على نطاق واسع.","description_en":"The modeling adheres to the family language of Capital Beauty, refining its unique characteristic lines in the large-scale modeling."},{"image_ar":"414_x3.jpg","image_en":"594_x3.jpg","title_ar":"تصميم إضاءة ذيل جناح القوة","title_en":"Kylin Wing Tail Light Design","description_ar":"المصباح الخلفي الجديد يلتزم بمفهوم التصميم العام، حيث أن المصفوفة الرقمية تشبه جناح الطائر جناح كيلين.","description_en":"The new tail light adheres to the overall design concept, the Digital Matrix is like a flying wing – Kylin Wing."},{"image_ar":"60_x4.jpg","image_en":"225_x4.jpg","title_ar":"تصميم نظام العادم الرباعي الثنائي","title_en":"Bilateral Quadruple Exhaust Design","description_ar":"تصميم العادم الثنائي الرباعي يبرز الديناميكية والقوة لـ ALL NEW X7.","description_en":"Bilateral and quadruple exhaust design highlights dynamic and power of ALL NEW X7."}]},{"section2":[{"image_ar":"31_all2.jpg","image_en":"292_all2.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"70_all3.jpg","image_en":"572_all3.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"549_all6.jpg","image_en":"267_all6.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"504_796_x4.jpg","image_en":"965_796_x4.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""}]},{"section3":[{"image_ar":"490_690_all12.jpg","image_en":"609_690_all12.jpg","title_ar":"التحكم المتكامل في السرعة التكيفي (IACC)","title_en":"Integrated Adaptive Cruiser Control (IACC)","description_ar":"يتكيف بذكاء مع السرعة المحددة مسبقًا ويقوم تلقائيًا بتغيير الأهداف، مما يخفف الضغط عن قدميك ويسمح بتجربة قيادة أكثر استرخاءًا.","description_en":"It intelligently adapts to the preset speed and automatically switches targets, taking the load off your feet and allowing for a more relaxed  driving experience."},{"image_ar":"264_82_all13.jpg","image_en":"102_82_all13.jpg","title_ar":"تحذير الانحراف عن المسار","title_en":"Lane Departure Warning (LDW)","description_ar":"يهدف إلى مساعدة السائقين على تقليل خطر الانحراف غير المقصود عن المسارات في الطرق السريعة، والطرق السريعة، والطرق الرئيسية من خلال تنبيهات بصرية وصوتية.","description_en":"It aims to help drivers minimize the risk of unintended lane departures on highways, expressways, and main roads by both visual and auditory alerts."},{"image_ar":"953_i21.jpg","image_en":"313_i21.jpg","title_ar":"الكشف عن النقطة العمياء","title_en":"Blind Spot Detection (BSD)","description_ar":"أثناء القيادة، يستخدم نظام الكشف عن نقطة العميان رادار موجات المليمتر للكشف عن نقاط العميان في الجزء الخلفي من السيارة على كلا الجانبين، مما يقلل من خطر حوادث المرور الناجمة عن نقاط العميان.","description_en":"While driving, the blind spot detection system uses millimeter-wave radar to detect blind spots at the rear of the vehicle on both sides, reducing the risk of traffic accidents caused by blind spots."},{"image_ar":"91_all14.jpg","image_en":"315_all14.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"531_all15.jpg","image_en":"53_all15.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""}]},{"section4":[{"image_ar":"119_all14.jpg","image_en":"826_all14.jpg","title_ar":"تحذير التصادم الأمامي","title_en":"Forward Collision Warning (FCW)","description_ar":"يُنبه السائق من خلال تحذيرات سمعية وبصرية عندما يصبح الاقتراب من السيارة الأمامية خطيرًا، مما يساعد السائق على الحفاظ على مسافة آمنة من السيارة الأمامية ومنع حوادث الاصطدام الخلفي.","description_en":"lt alerts the driver through auditory and visual warnings when the distance to the preceding vehicle becomes dangerously close, helping the driver maintain a safe distance from the vehicle ahead and prevent rear-end collisions."},{"image_ar":"799_all15.jpg","image_en":"604_all15.jpg","title_ar":"الفرملة الطارئة الذاتية","title_en":"Autonomous Emergency Braking (AEB)","description_ar":"يكتشف المشاة أو المركبات أمام السيارة ويصدر إنذارًا في حالة وجود خطر اصطدام. تحكم في السلامة، لا تتبع للسيارات بالقرب منك.","description_en":"Autonomous Emergency Braking (AEB)"},{"image_ar":"718_597_all8.jpg","image_en":"758_597_all8.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"288_470_658_all7.jpg","image_en":"848_470_658_all7.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""}]}],"categoryId":14,"meta_description":null,"meta_title":null,"meta_keywords":null,"createdAt":"2025-01-14T12:59:56.000Z","updatedAt":"2025-01-31T10:39:18.000Z","modelCategoryId":null,"modelCategory":{"id":14,"name":"SUV","name_ar":"سيَّارة رياضيَّة متعدِّدة الأغراض","createdAt":"2024-06-20T13:32:09.000Z","updatedAt":"2024-08-29T08:57:06.000Z"}},{"id":11,"name":"X55 II","name_ar":"X55 II","description":"Vogue Beast Arrival","description_ar":"الوحش الأنيق","image1":"729_1722262688SUV.png","image1_title":"","image1_title_ar":"","image1_description":"","image1_description_ar":"","image2":"156_1722262688SUV.png","image2_title":"","image2_title_ar":"","image2_description":"","image2_description_ar":"","modelAndConfiguration":"","vr_link":"https://www.baicglobal.com/x55/?car=X6&lang=en","power":"138/5500","torque":"275/1500-4500","wheelbase":"2735","moreSections":null,"designType":"normal","normalSections":[{"image_ar":"516_ar41.jpg","image_en":"27_41.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"670_ar42.jpg","image_en":"201_42.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"477_ar44.jpg","image_en":"411_43.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"241_ar43.jpg","image_en":"122_44.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"113_ar45.jpg","image_en":"683_441.jpg","title_ar":"","title_en":"","description_ar":"","description_en":""},{"image_ar":"81_ar46.jpg","image_e